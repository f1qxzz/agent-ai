# O-W-O Familiar identity
AGENT_NAME=O-W-O
AGENT_OWNER=@f1qxzz

# Telegram
TELEGRAM_BOT_TOKEN=
OWNER_TELEGRAM_ID=
TELEGRAM_USER_ID=

# Project scope
PROJECT_ROOT=
WORKSPACE_DIR=

# AI provider
AI_PROVIDER=
AI_MODEL=
AI_AUTO_FALLBACK=
AI_FALLBACK_ORDER=
AI_PROVIDER_TIMEOUT_MS=180000

# Optional provider keys
GEMINI_API_KEY=
KIRO_API_KEY=
KIRO_CLI_COMMAND=kiro-cli

# Runtime safety
SAFE_MODE=true
REQUIRE_APPROVAL_FOR_DESTRUCTIVE=true
REQUIRE_APPROVAL_FOR_PUBLIC_POST=true
REQUIRE_APPROVAL_FOR_FORCE_PUSH=true
COMMAND_TIMEOUT_MS=300000
MAX_OUTPUT_CHARS=15000
DEFAULT_SHELL=powershell
GIT_BASH_PATH=
NGROK_AUTHTOKEN=

# GitHub connector
ENABLE_GITHUB_CONNECTOR=
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=
GITHUB_OAUTH_CLIENT_ID=

# Discord connector
ENABLE_DISCORD_CONNECTOR=
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_GUILD_ID=
DISCORD_ALLOWED_CHANNEL_IDS=

# X connector
ENABLE_X_CONNECTOR=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=

# Never paste tokens into Telegram chat. Put secrets in .env or
# ~/.agent/credentials/<service>.env and only share masked status.
